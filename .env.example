# Database connection (Async SQLAlchemy / Alembic)
DB_HOST=aws-1-eu-west-1.pooler.supabase.com
DB_PORT=6543
DB_NAME=postgres
DB_USER=postgres.wrfpliqmzmrrpaglkpkp
DB_PASSWORD=your-password-here
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/reporting_db

# Auth / JWT
JWT_SECRET=change-me-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_TTL_MIN=15
REFRESH_TOKEN_TTL_DAYS=7

# CORS
CORS_ALLOW_ORIGINS=http://localhost:3000,http://localhost:5173

# SMTP (billing: send / resend invoice emails). Required for POST /billing/send-invoice-email and .../resend.
# Preview does not use SMTP. Port 465 uses implicit TLS; 587 uses STARTTLS unless SMTP_STARTTLS=false.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_STARTTLS=true

# After Google SSO, redirect browser to frontend with ?code=... (optional; omit for JSON-only callback)
FRONTEND_URL=http://localhost:3000
FRONTEND_SSO_SUCCESS_PATH=/auth/callback

# OIDC (optional)
OIDC_GOOGLE_CLIENT_ID=
OIDC_GOOGLE_CLIENT_SECRET=
OIDC_GOOGLE_REDIRECT_URI=http://localhost:8000/auth/sso/google/callback
OIDC_MICROSOFT_CLIENT_ID=
OIDC_MICROSOFT_CLIENT_SECRET=
OIDC_MICROSOFT_REDIRECT_URI=http://localhost:8000/auth/sso/microsoft/callback

# Asset invoice uploads (POST .../companies/{id}/assets/{asset_id}/invoice)
# ASSET_STORAGE_BACKEND=local — files under ASSET_LOCAL_STORAGE_PATH (default: var/asset_uploads).
# ASSET_STORAGE_BACKEND=s3 — use S3/MinIO below.
ASSET_STORAGE_BACKEND=local
ASSET_LOCAL_STORAGE_PATH=var/asset_uploads
# Optional base URL for invoice_file_url in API responses (no trailing slash). Serve this path via your reverse proxy or static mount.
ASSET_LOCAL_PUBLIC_BASE_URL=
ASSET_INVOICE_MAX_MB=10

# S3 / MinIO (only when ASSET_STORAGE_BACKEND=s3)
S3_BUCKET=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
S3_ENDPOINT_URL=
# Optional public URL prefix for invoice links (no trailing slash). If unset with s3, API returns presigned GET URLs.
S3_PUBLIC_BASE_URL=
